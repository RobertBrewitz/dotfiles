{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["custom/voxtype", "custom/recording", "custom/caffeine", "hyprland/language", "bluetooth", "network", "pulseaudio", "backlight", "battery", "power-profiles-daemon", "custom/power"],

    "hyprland/workspaces": {
        "format": "{name}"
    },
    "hyprland/language": {
        "format": "َ°ŒŒ {}",
        "format-en": "EN",
        "format-sv": "SV",
        "format-pl": "PL"
    },
    "clock": {
        "format": "َ°¥”  {:%a %b %d  %H:%M}",
        "tooltip-format": "{:%Y-%m-%d}"
    },
    "network": {
        "format-wifi": "َ°¤¨ {signalStrength}%",
        "format-ethernet": "َ°ˆ€",
        "format-disconnected": "َ°¤­",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)",
        "on-click": "nm-connection-editor"
    },
    "bluetooth": {
        "format": "َ°‚¯",
        "format-off": "َ°‚²",
        "format-connected": "َ°‚± {num_connections}",
        "on-click": "blueman-manager"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں",
        "format-icons": {
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "pavucontrol"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
        "on-scroll-up": "brightnessctl -d intel_backlight set +5%",
        "on-scroll-down": "brightnessctl -d intel_backlight set 5%-"
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "format-charging": "َ°‚„ {capacity}%",
        "tooltip-format": "{timeTo}\n{capacity}%\n{power}W"
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "format-icons": {
            "performance": "َ°“…",
            "balanced": "َ°¾…",
            "power-saver": "َ°¾†"
        },
        "tooltip-format": "Power profile: {profile}"
    },
    "custom/voxtype": {
        "exec": "voxtype status --follow --format json",
        "return-type": "json",
        "format": "{}",
        "tooltip": true
    },
    "custom/recording": {
        "exec": "if [ -f /tmp/capture-recording.pid ] && kill -0 $(cat /tmp/capture-recording.pid) 2>/dev/null; then echo 'َ°»‚'; else echo ''; fi",
        "interval": 1,
        "tooltip": false,
        "on-click": "~/.local/bin/capture"
    },
    "custom/caffeine": {
        "exec": "~/.local/bin/caffeine status",
        "return-type": "json",
        "interval": "once",
        "signal": 8,
        "on-click": "~/.local/bin/caffeine toggle",
        "tooltip": true
    },
    "custom/power": {
        "format": "َ°گ¥",
        "tooltip": false,
        "on-click": "~/.local/bin/powermenu"
    }
}
