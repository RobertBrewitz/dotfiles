{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["custom/voxtype", "custom/recording", "custom/caffeine", "hyprland/language", "bluetooth", "network", "pulseaudio", "backlight", "battery", "power-profiles-daemon"],

    "hyprland/workspaces": {
        "format": "{name}"
    },
    "hyprland/language": {
        "format": "蟀寣 {}",
        "format-en": "EN",
        "format-sv": "SV",
        "format-pl": "PL"
    },
    "clock": {
        "format": "蟀  {:%a %b %d  %H:%M}",
        "tooltip-format": "{:%Y-%m-%d}"
    },
    "network": {
        "format-wifi": "蟀え {signalStrength}%",
        "format-ethernet": "蟀垁",
        "format-disconnected": "蟀き",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)",
        "on-click": "nm-connection-editor"
    },
    "bluetooth": {
        "format": "蟀偗",
        "format-off": "蟀偛",
        "format-connected": "蟀偙 {num_connections}",
        "on-click": "blueman-manager"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "蟀潫",
        "format-icons": {
            "default": ["蟀暱", "蟀杸", "蟀暰"]
        },
        "on-click": "pavucontrol"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["蟀優", "蟀儫", "蟀儬"],
        "on-scroll-up": "brightnessctl -d intel_backlight set +5%",
        "on-scroll-down": "brightnessctl -d intel_backlight set 5%-"
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["蟀伜", "蟀伝", "蟀伡", "蟀伣", "蟀伨", "蟀伩", "蟀個", "蟀倎", "蟀倐", "蟀伖"],
        "format-charging": "蟀倓 {capacity}%",
        "tooltip-format": "{timeTo}\n{capacity}%\n{power}W"
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "format-icons": {
            "performance": "蟀搮",
            "balanced": "蟀緟",
            "power-saver": "蟀締"
        },
        "tooltip-format": "Power profile: {profile}"
    },
    "custom/voxtype": {
        "exec": "voxtype status --follow --format json",
        "return-type": "json",
        "format": "{}",
        "tooltip": true
    },
    "custom/recording": {
        "exec": "if [ -f /tmp/capture-recording.pid ] && kill -0 $(cat /tmp/capture-recording.pid) 2>/dev/null; then echo '蟀粋'; else echo ''; fi",
        "interval": 1,
        "tooltip": false,
        "on-click": "~/.local/bin/capture"
    },
    "custom/caffeine": {
        "exec": "~/.local/bin/caffeine status",
        "return-type": "json",
        "interval": "once",
        "signal": 8,
        "on-click": "~/.local/bin/caffeine toggle",
        "tooltip": true
    }
}
