#!/bin/bash

set -e

choice=$(printf '%s\n' \
    "箚뙻  Lock" \
    "箚뿽  Logout" \
    "箚뮧  Suspend" \
    "箚쐣  Reboot" \
    "箚맓  Shutdown" \
    | wofi --dmenu --prompt "Power" --width 260 --height 280 --cache-file /dev/null)

case "$choice" in
    *Lock)     hyprlock ;;
    *Logout)   hyprctl dispatch exit ;;
    *Suspend)  systemctl suspend ;;
    *Reboot)   systemctl reboot ;;
    *Shutdown) systemctl poweroff ;;
esac
